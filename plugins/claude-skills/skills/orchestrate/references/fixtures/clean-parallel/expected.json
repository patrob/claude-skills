    { "path": "workstreams.clip-editor.status", "equals": "complete" },
    { "path": "workstreams.clip-editor.verify_attempts_used", "equals": 1 },
    { "path": "quarantined", "equals": [] },
    { "path": "scope_deviations", "equals": [] },
